############################################################
### 1. 基础架构配置（硬件适配核心，不可修改，修改会导致固件不兼容）
############################################################

### Target Vendor/Product (support only Ralink RT3883/MT7620/MT7621/MT7628)
# 厂商选择：Padavan 固件仅支持 Ralink 系列芯片，固定为 Ralink
CONFIG_VENDOR=Ralink  
# 产品架构：路由器硬件芯片为 MT7621，必须与芯片型号一致（必需配置）
CONFIG_PRODUCT=MT7621  

### Target ProductID (board select, max 12 symbols)
# 设备型号 ID：与路由器硬件型号 JDCLOUD-RE-CP-02 匹配，最长 12 字符（必需配置）
CONFIG_FIRMWARE_PRODUCT_ID="RE-CP-02"

### Linux kernel and toolchain
# 启用 SFE 网络加速：提升路由转发速率，降低延迟（推荐开启，非必需但强烈建议）
# 对后续 VLESS 代理的网络稳定性有正向提升
CONFIG_FIRMWARE_INCLUDE_SFE=y
# 内核源码目录：指定使用 linux-4.4.x 内核（Padavan-4.4 分支固定路径，必需配置）
CONFIG_LINUXDIR=linux-4.4.x

############################################################
### 2. Linux 内核配置（底层功能支持，影响硬件兼容性和核心能力）
############################################################

### Enable IPv6 support
# 启用 IPv6 支持：VLESS 节点多数支持 IPv6，后续代理必需开启（必需配置）
# 即使仅使用 IPv4 节点，开启后也不影响兼容性，避免后续修改
CONFIG_FIRMWARE_ENABLE_IPV6=y

### Enable USB support
# 启用 USB 总线功能：支持 USB 存储（U盘/硬盘）、USB 网卡等外设（非必需，按需开启）
# 若路由器无 USB 接口可设为 n，有则开启，不影响 VLESS 代理
CONFIG_FIRMWARE_ENABLE_USB=y

### Enable FAT/FAT32 filesystem support. ~0.1MB
# 支持 FAT/FAT32 文件系统：U盘、移动硬盘最常用格式（必需配置，即使无 USB 也建议保留）
CONFIG_FIRMWARE_ENABLE_FAT=y

### Enable exFAT (FAT/FAT32 too) filesystem support. ~0.12MB
# 支持 exFAT 文件系统：大容量 U 盘/移动硬盘常用（非必需，按需开启）
# 单文件超过 4GB 需开启，不影响 VLESS 代理
CONFIG_FIRMWARE_ENABLE_EXFAT=y

### Enable EXT2 filesystem support. ~0.1MB
# 禁用 EXT2 文件系统：老旧格式，极少使用，关闭节省固件体积（非必需）
CONFIG_FIRMWARE_ENABLE_EXT2=n

### Enable EXT3 filesystem support. ~0.2MB
# 禁用 EXT3 文件系统：EXT4 已兼容 EXT3/EXT2，无需重复开启（非必需）
CONFIG_FIRMWARE_ENABLE_EXT3=n

### Enable EXT4 (EXT3/2 too) filesystem support. ~0.4MB
# 支持 EXT4 文件系统：Linux 常用格式，硬盘分区首选（非必需，有 USB 硬盘则开启）
CONFIG_FIRMWARE_ENABLE_EXT4=y

### Enable XFS filesystem support. ~0.6MB
# 禁用 XFS 文件系统：服务器级格式，路由器极少使用，关闭节省体积（非必需）
CONFIG_FIRMWARE_ENABLE_XFS=n

### Enable FUSE (filesystems in userspace) support. ~0.1MB
# 启用 FUSE 文件系统：用户态文件系统，后续 OpenClash/Clash 插件依赖（必需配置）
CONFIG_FIRMWARE_ENABLE_FUSE=y

### Enable swap files/partitions support. ~0.05MB
# 禁用 SWAP 支持：路由器内存小（通常 128MB/256MB），开启后性能下降（非必需）
CONFIG_FIRMWARE_ENABLE_SWAP=n

### Include UVC camera modules. ~0.2MB
# 禁用 UVC 摄像头模块：路由器极少连接摄像头，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_UVC=n

### Include USB-HID modules. ~0.2MB
# 禁用 USB-HID 模块：鼠标/键盘等外设，路由器无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_HID=n

### Include USB-Serial modules (e.g. pl2303). ~0.03MB
# 禁用 USB-Serial 模块：串口设备（如调试器），普通用户无需（非必需）
CONFIG_FIRMWARE_INCLUDE_SERIAL=n

### Include USB-Audio modules ~0.46MB
# 禁用 USB-Audio 模块：音频设备，路由器无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_AUDIO=n

### Include XFRM (IPsec) modules & iptables extension ~ 0.2MB
# 禁用 XFRM 模块：IPsec VPN 相关，与 VLESS 代理无关，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_XFRM=n

### Include network QoS scheduling modules. ~0.2MB
# 禁用 QoS 调度模块：流量控制功能，简单路由无需，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_QOS=y

### Include IMQ module for shapers (a bit of performance degradation). ~0.02MB
# 禁用 IMQ 整形模块：QoS 依赖，已禁用 QoS 则关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_IMQ=y

### Include IFB module for shapers. ~0.03MB
# 禁用 IFB 整形模块：QoS 依赖，已禁用 QoS 则关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_IFB=y

### Include IPSet utility and kernel modules. ~0.4MB
# 启用 IPSet 工具：IP/域名规则匹配，后续 OpenClash 域名分流必需（必需配置）
CONFIG_FIRMWARE_INCLUDE_IPSET=y

### Include NFSv3 server. ~0.6MB
# 禁用 NFSv3 服务器：路由器作为共享服务器极少使用，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_NFSD=n

### Include NFSv3 client. ~0.5MB
# 启用 NFSv3 客户端：访问局域网 NFS 共享文件夹（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_NFSC=y

### Include CIFS (SMB) client. ~0.2MB
# 禁用 CIFS 客户端：访问 Windows 共享文件夹，非必需（按需开启）
CONFIG_FIRMWARE_INCLUDE_CIFS=y

############################################################
### 3. Userspace configuration（用户态工具/插件，决定固件最终功能）
############################################################

### Include WebUI international resources. Increased firmware size
# 启用中文 WebUI：中文用户必需，保留该配置（必需配置）
CONFIG_FIRMWARE_INCLUDE_LANG_CN=y
# 以下其他语言默认禁用，保留注释不删除（非必需）
#CONFIG_FIRMWARE_INCLUDE_LANG_BR=n
#CONFIG_FIRMWARE_INCLUDE_LANG_CZ=n
#CONFIG_FIRMWARE_INCLUDE_LANG_DA=n
#CONFIG_FIRMWARE_INCLUDE_LANG_DE=n
#CONFIG_FIRMWARE_INCLUDE_LANG_ES=n
#CONFIG_FIRMWARE_INCLUDE_LANG_FI=n
#CONFIG_FIRMWARE_INCLUDE_LANG_FR=n
#CONFIG_FIRMWARE_INCLUDE_LANG_NO=n
#CONFIG_FIRMWARE_INCLUDE_LANG_PL=n
#CONFIG_FIRMWARE_INCLUDE_LANG_RU=n
#CONFIG_FIRMWARE_INCLUDE_LANG_SV=n
#CONFIG_FIRMWARE_INCLUDE_LANG_UK=n

### Include NTFS-3G FUSE driver (instead of Paragon "ufsd"). ~0.4MB
# 禁用 NTFS-3G 驱动：EXT4/FAT/exFAT 已覆盖常用场景，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_NTFS_3G=n

### Include LPR printer daemon. ~0.12MB
# 启用 LPR 打印机守护进程：连接网络打印机需开启，否则可关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_LPRD=y

### Include USB-over-Ethernet printer daemon. ~0.05MB
# 禁用 USB-以太网打印机 daemon：极少使用，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_U2EC=n

### Include "tcpdump" utility. ~0.6MB
# 启用 tcpdump 工具：网络抓包，后续调试 VLESS 代理连接问题必需（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

### Include "hdparm" utility (allow set HDD spindown timeout and APM). ~0.1MB
# 禁用 hdparm 工具：硬盘参数设置，路由器无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_HDPARM=n

### Include "parted" utility (allow make GPT partitions). ~0.3MB
# 启用 parted 工具：硬盘分区工具，格式化 USB 硬盘用（非必需，有硬盘则开启）
CONFIG_FIRMWARE_INCLUDE_PARTED=y

### Include SMB3.6 (and WINS) server. ~1.5MB
# 禁用 SMB3.6 服务器：路由器作为文件共享服务器极少使用，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_SMBD=n

### Include WINS server only. ~0.4MB
# 禁用 WINS 服务器：与 SMB 配合使用，已禁用 SMB 则关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_WINS=n

### Include syslog for SMB and WINS server. ~0.3MB
# 禁用 SMB 日志：已禁用 SMB 服务器，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=n

### Include FTP server. ~0.2MB
# 启用 FTP 服务器：访问 USB 存储文件（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_FTPD=y

### Include alternative L2TP control client RP-L2TP. ~0.1MB
# 禁用 L2TP 客户端：不使用 L2TP VPN 则关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_RPL2TP=n

### Include EAP-TTLS and EAP-PEAP authentication support. openssl ~1.2MB, wpa_supplicant +0.04MB
# 启用 EAP-PEAP 认证：部分校园网/企业网需要，开启不影响 VLESS 代理（非必需）
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y

### Include HTTPS support. openssl ~1.2MB
# 禁用 HTTPS 支持：无需则关闭，节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_HTTPS=n

### Include sftp-server. openssl ~1.2MB, sftp-server ~0.06MB
# 启用 SFTP 服务器：安全文件传输，比 FTP 更安全（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_SFTP=y

### Include dropbear SSH. ~0.3MB
# 禁用 Dropbear SSH：已启用 OpenSSH，功能更全，无需重复开启（非必需）
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=n

### Make the dropbear symmetrical ciphers and hashes faster. ~0.06MB
# 禁用 Dropbear 加速：已禁用 Dropbear，无需开启（非必需）
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=n

### Include OpenSSH instead of dropbear. openssl ~1.2MB, openssh ~1.0MB
# 启用 OpenSSH：SSH 远程管理路由器，功能比 Dropbear 全（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

### Include OpenVPN. IPv6 required. openssl ~1.2MB, openvpn ~0.4MB
# 启用 OpenVPN：VPN 客户端/服务端，与 VLESS 代理不冲突（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_OPENVPN=y

### Include StrongSwan. XFRM modules ~0.2MB, strongswan ~0.7MB
# 禁用 StrongSwan：IPsec VPN 工具，与 VLESS 无关，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_SSWAN=n

### Include Elliptic Curves (EC) to openssl library. ~0.1MB
# 启用 OpenSSL 椭圆曲线加密：OpenClash/Clash 及 OpenVPN 依赖（必需配置）
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y

### Include "openssl" executable for generate certificates. ~0.4MB
# 启用 OpenSSL 命令行工具：生成加密证书，调试 VLESS 加密问题（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y

### Include xUPNPd IPTV mediaserver. ~0.3MB
# 启用 xUPNPd：IPTV 媒体服务器，使用 IPTV 则开启（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_XUPNPD=n

### Include Minidlna UPnP mediaserver. ~1.6MB
# 禁用 Minidlna：UPnP 媒体服务器，极少使用，关闭节省体积（非必需）
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n

### Include Firefly iTunes mediaserver. ~1.0MB
# 禁用 Firefly：iTunes 媒体服务器，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_FIREFLY=n

### Include ffmpeg 0.11.x instead of 0.6.x for Minidlna and Firefly. ~0.1MB
# 启用新版 ffmpeg：xUPNPd 依赖，已开启 xUPNPd 则必需（非必需，随 xUPNPd 开启）
CONFIG_FIRMWARE_INCLUDE_FFMPEG_NEW=n

### Include Transmission torrent. openssl ~1.2MB, transmission ~1.5MB
# 禁用 Transmission：BT 下载工具，体积大，不使用则关闭（非必需）
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n

### Include Transmission-Web-Control (advanced WebUI). ~0.8MB
# 禁用 Transmission WebUI：已禁用 Transmission，无需开启（非必需）
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=n

### Include Aria2 download manager. openssl ~1.2MB, aria2 ~3.5MB
# 启用 Aria2：多协议下载工具（HTTP/HTTPS/FTP），支持离线下载（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_ARIA=n

### Include Aria2 WEB control. ~0.7MB
# 启用 Aria2 WebUI：网页管理下载任务，启用 Aria2 则必需（非必需，随 Aria2 开启）
CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=n

# 启用 curl 工具：HTTP 请求工具，OpenClash 订阅解析/节点测试依赖（必需配置）
CONFIG_FIRMWARE_INCLUDE_CURL=y

# 禁用 SCUT 客户端：特定校园网认证，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_SCUTCLIENT=n

# 禁用 GDUT DRCOM 客户端：特定校园网认证，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_GDUT_DRCOM=n

# 禁用 Dogcom 客户端：特定校园网认证，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_DOGCOM=n

# 禁用 Minieap 客户端：特定校园网认证，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_MINIEAP=n

# 禁用 NJIT 客户端：特定校园网认证，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_NJIT_CLIENT=n

# 禁用 SoftEther VPN 服务器：无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_SERVER=n

# 禁用 SoftEther VPN 客户端：无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_CLIENT=n

# 禁用 SoftEther VPN 命令行工具：无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_CMD=n

# 启用 VLMCSD：KMS 激活工具，按需开启（非必需）
CONFIG_FIRMWARE_INCLUDE_VLMCSD=y

# 启用 ttyd：Web 终端，远程管理路由器（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_TTYD=y

# 禁用 lrzsz：串口文件传输，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_LRZSZ=n

# 启用 htop：系统监控工具，查看进程/资源占用（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_HTOP=y

# 启用 nano：命令行文本编辑器，修改配置文件（必需配置）
CONFIG_FIRMWARE_INCLUDE_NANO=y

# 启用 iperf3：网络测速工具，调试 VLESS 代理网速（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_IPERF3=y

# 禁用 dump1090：飞机雷达接收工具，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_DUMP1090=n

# 禁用 RTL-SDR：无线电接收工具，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_RTL_SDR=n

# 启用 mtr：网络路由跟踪工具，调试 VLESS 代理连接路径（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_MTR=y

# 启用 socat：端口转发/网络中继，调试 VLESS 端口问题（推荐开启，非必需但实用）
CONFIG_FIRMWARE_INCLUDE_SOCAT=y

# 启用 srelay：简单中继工具，按需开启（非必需）
CONFIG_FIRMWARE_INCLUDE_SRELAY=y

# 禁用 Mentohust：校园网认证工具，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_MENTOHUST=n

# 禁用 FRPC：内网穿透客户端，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_FRPC=n

# 禁用 FRPS：内网穿透服务器，无需使用（非必需）
CONFIG_FIRMWARE_INCLUDE_FRPS=n

# 启用 WireGuard：轻量 VPN，与 VLESS 代理不冲突（非必需，按需开启）
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

############################################################
### 4. Mihomo（Clash Meta）核心配置（保留原文件名，支持 VLESS）
############################################################
# 启用 OpenClash 插件（trunk/user 路径集成）
CONFIG_USER_OPENCLASH=y

# Mihomo 核心基础配置（保留原文件名，关键！）
CONFIG_FIRMWARE_INCLUDE_OPENCLASH=y
CONFIG_FIRMWARE_INCLUDE_CLASH_CORE=y
CONFIG_FIRMWARE_CLASH_CORE_TYPE="Clash.Meta-linux-mipsle-softfloat-v1.10.0"  # 与核心原文件名完全一致
CONFIG_FIRMWARE_INCLUDE_CLASH_PREMIUM=n  # 禁用 Premium，Mihomo 单核心已含增强功能

# 分流规则配置（自动更新，无需手动维护）
CONFIG_FIRMWARE_INCLUDE_OPENCLASH_RULES=y
CONFIG_FIRMWARE_INCLUDE_GFWLIST=y  # 需代理域名列表
CONFIG_FIRMWARE_INCLUDE_CHINALIST=y  # 国内直连域名列表

############################################################
### 5. 依赖插件启用（trunk/user 目录下的必需依赖）
############################################################
# SmartDNS：DNS 分流、污染解决（OpenClash 必需）
CONFIG_USER_SMARTDNS=y
# jq：JSON 配置解析（订阅链接解析必需）
CONFIG_USER_JQ=y
# base64：订阅链接解码（必需）
CONFIG_USER_BASE64=y

############################################################
### 6. 内核级依赖补充（Mihomo + VLESS 运行必需）
############################################################
# TUN 模块：Mihomo TUN 模式支持（VLESS + WS/GRPC 传输必需）
CONFIG_FIRMWARE_ENABLE_TUN=y
# TProxy 模块：透明代理底层支持（路由器全局代理必需）
CONFIG_FIRMWARE_INCLUDE_TPROXY=y
# iptables 扩展：防火墙规则支持（分流、代理转发必需）
CONFIG_FIRMWARE_INCLUDE_IPTABLES_EXT=y
